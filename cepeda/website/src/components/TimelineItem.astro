---
export interface Props {
	day: string;
	title: string;
	description: string;
	emoji?: string;
}

const { day, title, description, emoji = "✨" } = Astro.props;
---
<div class="relative pl-8 sm:pl-32 py-6 group">
	<!-- Línea conectora central -->
	<div class="font-sans flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:inset-0 before:ml-5 sm:before:ml-[7.5rem] before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-[2px] before:bg-gradient-to-b before:from-ph-light before:to-gray-800">
		
		<div class="absolute left-0 sm:left-[5.5rem] mt-1 flex items-center justify-center w-10 h-10 rounded-full bg-black border-2 border-ph-light text-xl z-10 shadow-[0_0_10px_rgba(255,255,255,0.2)] group-hover:scale-110 transition-transform">
			{emoji}
		</div>
		
		<div class="mt-1 sm:mt-0 font-bold text-eje-equal text-xl w-32 shrink-0 sm:text-right sm:pr-8 italic font-serif">
			{day}
		</div>
		
		<div class="bg-gray-900 border border-gray-700 p-6 rounded-xl hover:border-ph-light transition-colors w-full relative -rotate-1 group-hover:rotate-0">
			<h4 class="text-xl font-bold text-white mb-2 font-['Comic_Sans_MS',cursive]">{title}</h4>
			<p class="text-gray-300 leading-relaxed">"{description}"</p>
		</div>

	</div>
</div>
