---
export interface Props {
	myth: string;
	reality: string;
	mythEmoji?: string;
	realityEmoji?: string;
}

const { myth, reality, mythEmoji = "🤔", realityEmoji = "💯" } = Astro.props;
---
<div class="group h-80 sm:h-96 lg:h-[26rem] w-full [perspective:1000px] cursor-pointer" role="button" tabindex="0" onclick="this.querySelector('.flip-inner').classList.toggle('[transform:rotateY(180deg)]')" onkeydown="if (event.key === 'Enter' || event.key === ' ') this.click()">
	<div class="flip-inner relative h-full w-full rounded-2xl shadow-xl transition-all duration-700 [transform-style:preserve-3d] group-hover:[transform:rotateY(180deg)]">
		
		<!-- Front: Myth -->
		<div class="absolute inset-0 bg-yellow-300 border-4 border-black p-4 sm:p-6 rounded-2xl flex flex-col justify-center items-center text-center [backface-visibility:hidden]">
			<span class="text-4xl mb-2 sm:mb-4">{mythEmoji}</span>
			<h4 class="font-bold text-black font-[Impact] tracking-wide text-xl sm:text-2xl uppercase">Mito</h4>
			<p class="flip-text text-black font-['Comic_Sans_MS',cursive] mt-2 sm:mt-3 leading-tight text-sm sm:text-base">{myth}</p>
			<span class="absolute bottom-3 right-4 text-[10px] sm:text-xs font-bold text-gray-800 rotate-2">¡Pasa el mouse o toca! 👉🏽</span>
		</div>

		<!-- Back: Reality -->
		<div class="absolute inset-0 h-full w-full rounded-2xl bg-ph-purple border-4 border-white p-4 sm:p-6 flex flex-col justify-center items-center text-center [transform:rotateY(180deg)] [backface-visibility:hidden] overflow-y-auto custom-scrollbar">
			<span class="text-3xl sm:text-4xl mb-2">{realityEmoji}</span>
			<h4 class="font-bold text-white text-lg sm:text-xl font-serif mb-2">LA VERDAD</h4>
			<p class="flip-text text-white font-sans leading-snug sm:leading-relaxed text-xs sm:text-sm my-auto">"{reality}"</p>
		</div>

	</div>
</div>

<style>
/* Ocultar barra de scroll para que no dañe el diseño, pero permitir scroll si el texto sigue siendo muy largo */
.custom-scrollbar::-webkit-scrollbar {
    display: none;
}
.custom-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
}
.flip-text {
	overflow-wrap: anywhere;
	hyphens: auto;
}
</style>
