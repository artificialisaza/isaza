---
---
<div id="emoji-rain-root" class="fixed inset-0 pointer-events-none z-[9998]"></div>
<button id="emoji-rain-toggle" class="fixed bottom-6 right-4 sm:right-6 z-[9999] bg-ph-light text-black px-4 py-2 rounded-full font-bold shadow-[4px_4px_0px_#000] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform">
	🌧️ Lluvia de emojis
</button>

<script is:inline>
	document.addEventListener('astro:page-load', () => {
		const root = document.getElementById('emoji-rain-root');
		const button = document.getElementById('emoji-rain-toggle');

		if (!root || !button) return;

		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReduced) {
			button.style.display = 'none';
			return;
		}

		const emojis = ["✨", "🌱", "🕊️", "⚡", "💜", "🌎", "💧", "✊🏾"];
		const isSmall = window.matchMedia('(max-width: 640px)').matches;
		const maxEmojis = isSmall ? 18 : 36;
		let active = false;
		let intervalId = null;

		function spawnEmoji() {
			if (!active) return;
			if (root.children.length >= maxEmojis) return;

			const emoji = document.createElement('span');
			const size = Math.floor(Math.random() * 16) + 16;
			const left = Math.random() * 100;
			const duration = Math.random() * 2.5 + 2.5;

			emoji.textContent = emojis[Math.floor(Math.random() * emojis.length)];
			emoji.style.position = 'absolute';
			emoji.style.left = `${left}%`;
			emoji.style.top = '-10%';
			emoji.style.fontSize = `${size}px`;
			emoji.style.animation = `emoji-fall ${duration}s linear forwards`;
			root.appendChild(emoji);

			emoji.addEventListener('animationend', () => {
				root.removeChild(emoji);
			});
		}

		function startRain() {
			active = true;
			button.setAttribute('aria-pressed', 'true');
			button.textContent = '⏸️ Pausar lluvia';
			intervalId = window.setInterval(spawnEmoji, 150);
		}

		function stopRain() {
			active = false;
			button.setAttribute('aria-pressed', 'false');
			button.textContent = '🌧️ Lluvia de emojis';
			if (intervalId) {
				window.clearInterval(intervalId);
				intervalId = null;
			}
		}

		button.addEventListener('click', () => {
			if (active) {
				stopRain();
			} else {
				startRain();
			}
		});
	});
</script>

<style>
@keyframes emoji-fall {
	0% {
		transform: translateY(0) rotate(0deg);
		opacity: 1;
	}
	100% {
		transform: translateY(120vh) rotate(180deg);
		opacity: 0.9;
	}
}
</style>
